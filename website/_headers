# Cloudflare Pages response headers

/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), camera=(), microphone=()

# Sitemap + robots: correct content type and a sensible cache.
/sitemap.xml
  Content-Type: application/xml; charset=utf-8
  Cache-Control: public, max-age=3600

/robots.txt
  Content-Type: text/plain; charset=utf-8
  Cache-Control: public, max-age=86400

# IndexNow key file: serve as plain text, never cache aggressively
# (search engines fetch it to verify ownership).
/c8f5d3a1e947b2f6a4c1b9d8e6f3a2b5.txt
  Content-Type: text/plain; charset=utf-8
  Cache-Control: public, max-age=300

# Static assets: aggressive cache (images are immutable in practice).
/assets/images/*
  Cache-Control: public, max-age=31536000, immutable

# CSS / JS: shorter, since we edit these.
/assets/css/*
  Cache-Control: public, max-age=86400
/assets/js/*
  Cache-Control: public, max-age=86400

# Blog markdown source files: short cache so updates are picked up.
/assets/blog/*
  Cache-Control: public, max-age=600
