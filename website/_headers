# Cloudflare Pages response headers

# Shared header / footer JS: short cache so banner + nav changes propagate
# within minutes. Listed before the generic /assets/js/* rule below so it
# takes precedence.
/assets/js/header.js
  Cache-Control: public, max-age=300

/assets/js/footer.js
  Cache-Control: public, max-age=300

# API endpoints: never cache, never index.
/api/*
  Cache-Control: no-cache, no-store, must-revalidate
  X-Robots-Tag: noindex

# Admin dashboard: never cache, never index, never frame.
# CSP allows jsdelivr (marked + dompurify in post-editor) and GitHub API
# (admin Functions round-trip through /api/* but some clients call directly).
/admin/*
  Cache-Control: no-cache, no-store, must-revalidate
  X-Frame-Options: DENY
  X-Robots-Tag: noindex
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https:; font-src 'self' data:; connect-src 'self' https://api.github.com; frame-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self' https://form.jotform.com; object-src 'none'

# Public pages CSP. Heavy use of inline <script>/<style> blocks (tailwind
# config, JSON-LD, hero anims, page-overrides) requires 'unsafe-inline'.
# Hosts enumerated: Jotform (embeds + form post), LeadTrap (lead-bot
# widget), jsdelivr (marked + dompurify on blog post template), Google
# Maps (iframe on location pages), and the common analytics hosts the
# /admin head-scripts injector pastes (GA4, FB Pixel, Hotjar, GTM).
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  X-XSS-Protection: 1; mode=block
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), camera=(), microphone=()
  Link: <https://form.jotform.com>; rel=preconnect; crossorigin, <https://cdn.jotfor.ms>; rel=preconnect; crossorigin, <https://app.leadtrap.ai>; rel=preconnect; crossorigin
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdn.jsdelivr.net https://form.jotform.com https://cdn.jotfor.ms https://app.leadtrap.ai https://www.googletagmanager.com https://www.google-analytics.com https://*.google-analytics.com https://www.googleadservices.com https://googleads.g.doubleclick.net https://www.google.com https://static.hotjar.com https://script.hotjar.com https://*.hotjar.com https://connect.facebook.net https://s.wc-data.com https://*.wc-data.com; script-src-elem 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://form.jotform.com https://cdn.jotfor.ms https://app.leadtrap.ai https://www.googletagmanager.com https://www.google-analytics.com https://*.google-analytics.com https://www.googleadservices.com https://googleads.g.doubleclick.net https://www.google.com https://static.hotjar.com https://script.hotjar.com https://*.hotjar.com https://connect.facebook.net https://s.wc-data.com https://*.wc-data.com; style-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://cdn.jotfor.ms; img-src 'self' data: blob: https:; font-src 'self' data: https://cdn.jotfor.ms; connect-src 'self' https://form.jotform.com https://cdn.jotfor.ms https://app.leadtrap.ai https://www.google-analytics.com https://*.analytics.google.com https://*.google-analytics.com https://www.googletagmanager.com https://www.googleadservices.com https://googleads.g.doubleclick.net https://www.google.com https://*.hotjar.com https://*.hotjar.io wss://*.hotjar.com https://connect.facebook.net https://s.wc-data.com https://*.wc-data.com; frame-src 'self' https://form.jotform.com https://www.jotform.com https://app.leadtrap.ai https://www.google.com https://td.doubleclick.net https://bid.g.doubleclick.net; media-src 'self' https:; frame-ancestors 'self'; base-uri 'self'; form-action 'self' https://form.jotform.com; object-src 'none'

# Sitemap + robots: correct content type and a sensible cache.
/sitemap.xml
  Content-Type: application/xml; charset=utf-8
  Cache-Control: public, max-age=3600

/robots.txt
  Content-Type: text/plain; charset=utf-8
  Cache-Control: public, max-age=86400

# IndexNow key file: serve as plain text, never cache aggressively
# (search engines fetch it to verify ownership).
/c8f5d3a1e947b2f6a4c1b9d8e6f3a2b5.txt
  Content-Type: text/plain; charset=utf-8
  Cache-Control: public, max-age=300

# Static assets: aggressive cache (images are immutable in practice).
/assets/images/*
  Cache-Control: public, max-age=31536000, immutable

# CSS / JS: short cache because we edit these frequently and the perf
# block + dispatcher behavior is keyed on shipping the latest. 86400 (a
# day) was painful in practice — a fix would land but users would still
# get yesterday's app.js for up to 24h. 5 min revalidate is a better
# trade until we move to content-hashed filenames.
/assets/css/*
  Cache-Control: public, max-age=300, must-revalidate
/assets/js/*
  Cache-Control: public, max-age=300, must-revalidate

# Blog markdown source files: short cache so updates are picked up.
/assets/blog/*
  Cache-Control: public, max-age=600
